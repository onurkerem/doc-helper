---
import Layout from "../layouts/Layout.astro";

const configJson = `{
  "confluence": {
    "baseUrl": "https://your-domain.atlassian.net",
    "spaceKey": "DEV",
    "parentPageId": "123456789",
    "userEmail": "user@domain.com"
  },
  "sync": {
    "rootDir": "./docs",
    "exclude": [".git", "node_modules", "drafts"]
  }
}`;
---

<Layout title="doc-helper - Markdown to Confluence Sync">
  <!-- Hero Section ("The Overhang") -->
  <header class="pt-32 pb-24 px-8 relative overflow-hidden bg-surface-bright flex flex-col items-center text-center border-b border-surface-container-low">
    <div class="max-w-4xl mx-auto relative z-10">
      <h1 class="text-6xl md:text-8xl font-headline font-extrabold tracking-tighter text-on-surface mb-6 leading-none">
        doc-helper
      </h1>
      <p class="text-xl md:text-2xl font-body text-on-surface-variant max-w-2xl mx-auto mb-12 font-light">
        Concatenate markdown files and sync to Confluence with ease.
      </p>

      <!-- Terminal Component -->
      <div class="bg-inverse-surface rounded-lg max-w-2xl mx-auto text-left shadow-[0px_24px_48px_rgba(45,52,53,0.15)] ring-1 ring-white/10 relative -mb-16 z-20">
        <!-- Title bar -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-white/[0.06]">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
          </div>
          <span class="text-xs font-mono text-on-surface-variant/40 tracking-wide">bash</span>
          <button
            class="flex items-center gap-1 text-on-surface-variant/40 hover:text-inverse-on-surface transition-colors cursor-pointer p-1 rounded hover:bg-white/[0.08]"
            title="Copy to clipboard"
            id="hero-copy-btn"
          >
            <span class="material-symbols-outlined text-base">content_copy</span>
          </button>
        </div>
        <!-- Command -->
        <div class="px-6 py-5">
          <code class="font-mono text-base leading-relaxed break-all block">
            <span class="text-tertiary-fixed select-none">$ </span><span class="text-[#8b9cf7]">curl</span> <span class="text-on-surface-variant/70">-fsSL</span> <span class="text-inverse-on-surface">https://raw.githubusercontent.com/onurkerem/doc-helper/main/packages/cli/install.sh</span> <span class="text-on-surface-variant/70">|</span> <span class="text-[#8b9cf7]">bash</span>
          </code>
        </div>
      </div>
    </div>

    <!-- Grid background -->
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl h-full pointer-events-none opacity-[0.03]"
      style="background-image: linear-gradient(#2d3435 1px, transparent 1px), linear-gradient(90deg, #2d3435 1px, transparent 1px); background-size: 64px 64px;"
    >
    </div>
  </header>

  <!-- Features Section -->
  <section class="py-32 px-8 bg-surface-container-low mt-16" id="features">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-headline font-bold mb-16 text-center text-on-surface tracking-tight">
        Core Capabilities
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="bg-surface-container-lowest p-8 border border-surface-container-highest transition-colors hover:border-outline-variant/30 group">
          <div class="w-12 h-12 bg-surface-container flex items-center justify-center rounded mb-6 text-on-surface group-hover:bg-primary group-hover:text-on-primary transition-colors">
            <span class="material-symbols-outlined">description</span>
          </div>
          <h3 class="text-xl font-headline font-bold mb-3 text-on-surface">Markdown Concatenation</h3>
          <p class="font-body text-on-surface-variant leading-relaxed mb-4">
            Combine multiple markdown files into a single, cohesive document. Easily copy the output to your clipboard for quick sharing.
          </p>
        </div>
        <!-- Feature 2 -->
        <div class="bg-surface-container-lowest p-8 border border-surface-container-highest transition-colors hover:border-outline-variant/30 group">
          <div class="w-12 h-12 bg-surface-container flex items-center justify-center rounded mb-6 text-on-surface group-hover:bg-primary group-hover:text-on-primary transition-colors">
            <span class="material-symbols-outlined">sync</span>
          </div>
          <h3 class="text-xl font-headline font-bold mb-3 text-on-surface">Confluence Sync</h3>
          <p class="font-body text-on-surface-variant leading-relaxed">
            Push your documentation directly to Confluence. The tool automatically maps your local directory hierarchy to Confluence pages.
          </p>
        </div>
        <!-- Feature 3 -->
        <div class="bg-surface-container-lowest p-8 border border-surface-container-highest transition-colors hover:border-outline-variant/30 group">
          <div class="w-12 h-12 bg-surface-container flex items-center justify-center rounded mb-6 text-on-surface group-hover:bg-primary group-hover:text-on-primary transition-colors">
            <span class="material-symbols-outlined">track_changes</span>
          </div>
          <h3 class="text-xl font-headline font-bold mb-3 text-on-surface">Smart Updates</h3>
          <p class="font-body text-on-surface-variant leading-relaxed">
            doc-helper uses hash tracking to ensure only modified files are uploaded, saving time and API calls during updates.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Usage Section -->
  <section class="py-32 px-8 bg-surface border-y border-surface-container-low" id="usage">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
      <div class="w-full lg:w-1/2">
        <h2 class="text-3xl md:text-4xl font-headline font-bold mb-6 text-on-surface tracking-tight">Usage</h2>
        <p class="font-body text-lg text-on-surface-variant mb-8 leading-relaxed">
          Execute doc-helper from your project root. Use flags to customize the build, exclude directories, or dry-run the sync process.
        </p>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-tertiary mt-1">check_circle</span>
            <p class="font-body text-on-surface-variant">Compile all markdown in the current directory.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-tertiary mt-1">check_circle</span>
            <p class="font-body text-on-surface-variant">Exclude specific paths from the build.</p>
          </div>
        </div>
      </div>
      <div class="w-full lg:w-1/2">
        <div class="bg-inverse-surface rounded-lg p-6 text-left shadow-[0px_24px_48px_rgba(45,52,53,0.06)] ring-1 ring-white/10 w-full">
          <div class="flex items-center justify-between mb-4 border-b border-surface-variant/20 pb-2">
            <span class="text-xs font-mono text-on-surface-variant uppercase tracking-widest">Terminal</span>
          </div>
          <div class="font-mono text-sm space-y-4">
            <div>
              <span class="text-on-surface-variant opacity-70"># Basic concatenation</span><br />
              <span class="text-tertiary-fixed">$</span> <span class="text-inverse-on-surface">doc-helper build</span>
            </div>
            <div>
              <span class="text-on-surface-variant opacity-70"># Build and copy to clipboard</span><br />
              <span class="text-tertiary-fixed">$</span> <span class="text-inverse-on-surface">doc-helper build --copy</span>
            </div>
            <div>
              <span class="text-on-surface-variant opacity-70"># Sync to Confluence, excluding drafts</span><br />
              <span class="text-tertiary-fixed">$</span> <span class="text-inverse-on-surface">doc-helper sync --exclude "./drafts"</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Confluence Sync / Hierarchy Mapping Section -->
  <section class="py-32 px-8 bg-surface-container-low" id="sync-guide">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-headline font-bold mb-8 text-center text-on-surface tracking-tight">
        Hierarchy Mapping
      </h2>
      <p class="font-body text-lg text-on-surface-variant mb-16 text-center max-w-3xl mx-auto">
        doc-helper reads your local folder structure and mirrors it in Confluence. <code class="bg-surface-container px-1 py-0.5 rounded text-on-surface text-base">overview.md</code> files act as the parent page for their respective directories.
      </p>
      <div class="bg-surface-container-lowest p-12 border border-surface-container-highest flex flex-col md:flex-row gap-12 items-stretch">
        <!-- Local Structure -->
        <div class="flex-1">
          <h4 class="font-headline font-bold text-on-surface mb-6 border-b border-surface-container-highest pb-2">Local Directory</h4>
          <div class="font-mono text-sm text-on-surface-variant space-y-2">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-base">folder</span> docs/
            </div>
            <div class="flex items-center gap-2 ml-4 text-tertiary">
              <span class="material-symbols-outlined text-base">description</span> overview.md
            </div>
            <div class="flex items-center gap-2 ml-4">
              <span class="material-symbols-outlined text-base">folder</span> api/
            </div>
            <div class="flex items-center gap-2 ml-8">
              <span class="material-symbols-outlined text-base">description</span> overview.md
            </div>
            <div class="flex items-center gap-2 ml-8">
              <span class="material-symbols-outlined text-base">description</span> endpoints.md
            </div>
            <div class="flex items-center gap-2 ml-4">
              <span class="material-symbols-outlined text-base">description</span> setup.md
            </div>
          </div>
        </div>
        <!-- Connector -->
        <div class="hidden md:flex flex-col items-center justify-center text-surface-container-highest">
          <div class="h-full w-px bg-surface-container-highest"></div>
          <div class="bg-surface-container-lowest p-2 border border-surface-container-highest rounded-full my-4">
            <span class="material-symbols-outlined text-on-surface-variant">arrow_forward</span>
          </div>
          <div class="h-full w-px bg-surface-container-highest"></div>
        </div>
        <!-- Confluence Structure -->
        <div class="flex-1">
          <h4 class="font-headline font-bold text-on-surface mb-6 border-b border-surface-container-highest pb-2">Confluence Pages</h4>
          <div class="font-body text-sm text-on-surface-variant space-y-3">
            <div class="flex items-center gap-2 text-tertiary font-medium">
              <span class="material-symbols-outlined text-base">article</span> Docs Overview (Parent)
            </div>
            <div class="flex flex-col gap-3 ml-6 border-l-2 border-surface-container pl-4">
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-base">article</span> API Overview
              </div>
              <div class="flex items-center gap-2 ml-6 text-on-surface-variant">
                <span class="material-symbols-outlined text-base text-surface-variant">horizontal_rule</span> Endpoints
              </div>
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-base">article</span> Setup Guide
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Setup Section -->
  <section class="py-32 px-8 bg-surface" id="setup">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-headline font-bold mb-6 text-on-surface tracking-tight">
        Simple Configuration
      </h2>
      <p class="font-body text-lg text-on-surface-variant mb-12">
        Set up your <code class="bg-surface-container px-1 py-0.5 rounded text-on-surface">doc-helper.json</code> file in the root of your project and provide your Confluence credentials.
      </p>
      <div class="bg-surface-container-low p-8 border border-outline-variant/15 text-left inline-block w-full max-w-2xl">
        <pre class="font-mono text-sm text-on-surface overflow-x-auto"><code set:html={configJson} /></pre>
      </div>
      <p class="font-body text-sm text-on-surface-variant mt-6">
        Requires <code class="bg-surface-container px-1 py-0.5 rounded text-on-surface">CONFLUENCE_API_TOKEN</code> set in your environment variables.
      </p>
    </div>
  </section>
</Layout>

<script>
  document.getElementById("hero-copy-btn")?.addEventListener("click", async (e) => {
    const btn = e.currentTarget as HTMLElement;
    const code = `curl -fsSL https://raw.githubusercontent.com/onurkerem/doc-helper/main/packages/cli/install.sh | bash`;
    await navigator.clipboard.writeText(code);
    const icon = btn.querySelector(".material-symbols-outlined");
    if (icon) {
      icon.textContent = "check";
      setTimeout(() => { icon.textContent = "content_copy"; }, 2000);
    }
  });
</script>
